# 服务端口
VITE_SERVER_PORT=6789

# 请求地址
VITE_BASE_URL=/api

# 代理地址
VITE_PROXY_URL=https://example.com

# 首选项语言
VITE_APP_LOCALE=zh

# app 标题
VITE_APP_TITLE=Vue3模板

# 是否在 dev 时启用 ESLint 自动 fix (true/false), 如果设置了编辑器自动 fix 可以关闭
VITE_ENABLE_ESLINT=true

# 是否启用构建产物 Bundle 分析 (true/false)
VITE_BUNDLE_ANALYZE=false

# 是否启用 MSW Mock 拦截接口请求 (true/false)
VITE_ENABLE_MOCK=true
