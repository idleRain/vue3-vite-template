{
  "name": "vue3-vite-template",
  "version": "0.1.0",
  "type": "module",
  "author": "IdleRain",
  "description": "一个开箱即用且技术栈最新的 Vue + Vite + TypeScript 轻量化项目工程基座",
  "license": "MIT",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite --mode dev",
    "build:test": "vite build --mode test",
    "build:preview": "vite build --mode preview",
    "build": "vite build --mode prod",
    "preview": "vite preview --mode prod",
    "ts": "vue-tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "i18n:type": "node --experimental-strip-types scripts/gen-i18n-types.ts",
    "format": "prettier --write \"src/**/*.{html,vue,ts,js,cjs,mjs}\"",
    "lint": "eslint src --fix --ext .ts,.tsx,.vue,.js,.jsx --max-warnings 0",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "check": "node --experimental-strip-types scripts/check.ts"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.2",
    "@lucide/vue": "^1.17.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "element-plus": "^2.14.1",
    "embla-carousel-vue": "^8.6.0",
    "gsap": "^3.15.0",
    "ky": "^2.0.2",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.10",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.5",
    "vue-input-otp": "^0.3.2",
    "vue-router": "^5.1.0",
    "vue-sonner": "^2.0.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "@vue/compiler-sfc": "^3.5.35",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "json5": "^2.2.3",
    "lint-staged": "^17.0.7",
    "minimatch": "^10.2.5",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-sort-imports": "^1.8.11",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.100.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vite-plugin-json5": "^1.4.4",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  },
  "lint-staged": {
    "*.{vue,ts,js,cjs,mjs}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{html,json,json5,md,css,scss}": [
      "prettier --write"
    ]
  },
  "homepage": "https://github.com/idleRain/vue3-vite-template#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/idleRain/vue3-vite-template.git"
  },
  "bugs": {
    "url": "https://github.com/idleRain/vue3-vite-template/issues"
  },
  "volta": {
    "node": "23.11.1",
    "pnpm": "11.5.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
